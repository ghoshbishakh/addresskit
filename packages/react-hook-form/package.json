  "dependencies": {
    "@addresskit/core": "workspace:*",
    "@addresskit/react": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-hook-form": ">=7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
